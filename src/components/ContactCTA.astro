---
/**
 * BACS Labs · ContactCTA
 *
 * Kapanış bölümü — pozisyonu netleştir, üç temas noktası ver.
 * "Sizin için de kurarım" mesajının somut karşılığı.
 */
---

<section class="relative overflow-hidden bg-[var(--color-bg-base)] py-20 lg:py-28">
  <!-- Subtle accent decoration -->
  <div class="pointer-events-none absolute inset-0 opacity-30">
    <div class="absolute right-0 top-1/2 h-96 w-96 -translate-y-1/2 translate-x-1/3 rounded-full bg-[var(--color-accent)] blur-[180px]"></div>
  </div>

  <div class="relative mx-auto max-w-5xl px-6">
    <div class="mb-3 flex items-center gap-3">
      <span class="h-px w-12 bg-[var(--color-accent)]"></span>
      <span class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-text-muted)]">
        Bir sonraki adım
      </span>
    </div>

    <h2 class="max-w-3xl text-3xl font-semibold leading-tight tracking-tight text-[var(--color-text-primary)] md:text-4xl lg:text-5xl">
      Sizin operasyonunuz için de <em class="not-italic text-[var(--color-accent)]">kurarım</em>.
    </h2>

    <p class="mt-5 max-w-2xl text-base leading-relaxed text-[var(--color-text-secondary)] md:text-lg">
      Bu repo bir bitmiş ürün değil — kanıt. Aynı engine zemini sizin TMS, fiyatlama platformu veya
      satınalma sistemi için özelleştirilebilir. 30 dakikalık görüşmede kapsamı netleştirelim;
      taahhüt yok.
    </p>

    <!-- 3 CTA -->
    <div class="mt-10 grid gap-3 md:grid-cols-3">
      <a
        href="https://calendly.com/barisanil/30min"
        target="_blank"
        rel="noopener"
        class="cta-card cta-primary"
      >
        <div class="cta-eyebrow">Toplantı</div>
        <div class="cta-title">30 dakikalık ön görüşme</div>
        <div class="cta-sub">Calendly · taahhüt yok</div>
        <div class="cta-arrow">→</div>
      </a>

      <a
        href="mailto:info@barisanil.com?subject=BACS%20Labs%20Vehicle-Aware%20Routing"
        class="cta-card"
      >
        <div class="cta-eyebrow">E-posta</div>
        <div class="cta-title">info@barisanil.com</div>
        <div class="cta-sub">Brief gönder, kapsam yaz</div>
        <div class="cta-arrow">→</div>
      </a>

      <a
        href="https://github.com/barisanil1975/bacs-vehicle-aware-routing"
        target="_blank"
        rel="noopener"
        class="cta-card"
      >
        <div class="cta-eyebrow">Kod</div>
        <div class="cta-title">GitHub repo</div>
        <div class="cta-sub">MIT lisansı · fork edilebilir</div>
        <div class="cta-arrow">→</div>
      </a>
    </div>

    <!-- Author info -->
    <div class="mt-14 border-t border-[var(--color-border-default)] pt-8">
      <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-center">
        <div>
          <div class="text-xs uppercase tracking-widest text-[var(--color-text-muted)]">
            Hakkında
          </div>
          <div class="mt-1 text-sm text-[var(--color-text-primary)]">
            <span class="font-semibold">Barış Anıl</span> · BACS Consultancy
          </div>
          <div class="mt-1 text-sm text-[var(--color-text-secondary)]">
            24+ yıl lojistik, tedarik zinciri ve dijital platform liderliği. Boğaz köprüsü algoritmaları,
            KGM tarife matrisleri ve fleet operasyonel mimarisi yazan.
          </div>
        </div>

        <a
          href="https://barisanil.com"
          target="_blank"
          rel="noopener"
          class="rounded-md border border-[var(--color-border-default)] bg-[var(--color-bg-elevated)] px-4 py-2 text-sm font-medium text-[var(--color-text-primary)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          barisanil.com →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    position: relative;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border-default);
    background: var(--color-bg-elevated);
    border-radius: 0.75rem;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      transform 0.15s ease,
      background 0.15s ease;
    display: flex;
    flex-direction: column;
    min-height: 130px;
  }
  .cta-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .cta-card.cta-primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }
  .cta-card.cta-primary:hover {
    background: color-mix(in srgb, var(--color-accent) 92%, white);
  }
  .cta-eyebrow {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }
  .cta-card.cta-primary .cta-eyebrow {
    color: rgba(255, 255, 255, 0.7);
  }
  .cta-title {
    margin-top: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.3;
  }
  .cta-card.cta-primary .cta-title {
    color: white;
  }
  .cta-sub {
    margin-top: 0.375rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    flex: 1;
  }
  .cta-card.cta-primary .cta-sub {
    color: rgba(255, 255, 255, 0.75);
  }
  .cta-arrow {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--color-accent);
    align-self: flex-end;
  }
  .cta-card.cta-primary .cta-arrow {
    color: white;
  }
</style>
