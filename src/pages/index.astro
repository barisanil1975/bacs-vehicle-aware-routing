---
/**
 * BACS Labs · index.astro
 *
 * Tek sayfa landing — final scope:
 *  - Hero (static)
 *  - Calculator (React island, client:load)
 *  - AlgoPanel (static, collapsible)
 *  - CaseStudy (static)
 *  - ContactCTA (static)
 *  - Footer
 */

import '../styles/global.css';
import Hero from '../components/Hero.astro';
import AlgoPanel from '../components/AlgoPanel.astro';
import CaseStudy from '../components/CaseStudy.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { Calculator } from '../components/Calculator';
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>BACS Labs · Vehicle-Aware Routing</title>
    <meta
      name="description"
      content="Türkiye iç pazarı için yön-bilinçli rota ve fiyatlama motoru — köprü sınıfı, KGM 2026 tarifeleri, akaryakıt eskalasyonu. BACS Consultancy yetkinlik vitrini."
    />

    <!-- Social / OG -->
    <meta property="og:title" content="BACS Labs · Vehicle-Aware Routing" />
    <meta
      property="og:description"
      content="Köprü sınıfı, yön bazlı waypoint, KGM 2026 tarife matrisi — 8 araç sınıfı için ayrı hesap. Megapol Lojistik için ürettiğim engine'in sanitize edilmiş public versiyonu."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://labs.barisanil.com" />
    <meta property="og:image" content="https://labs.barisanil.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="BACS Labs · Vehicle-Aware Routing" />
    <meta
      name="twitter:description"
      content="Türkiye'de spot araç fiyatı 'km × ₺/km' değildir. Engine kanıtı."
    />
    <meta name="twitter:image" content="https://labs.barisanil.com/og.png" />

    <!-- Leaflet CSS -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500;600&display=swap"
    />
  </head>

  <body class="min-h-screen bg-[var(--color-bg-base)] text-[var(--color-text-primary)]">
    <Hero />

    <!-- Calculator section -->
    <section class="bg-[var(--color-bg-base)] py-16 lg:py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-10">
          <div class="mb-3 flex items-center gap-3">
            <span class="h-px w-12 bg-[var(--color-accent)]"></span>
            <span class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-text-muted)]">
              Canlı Motor
            </span>
          </div>
          <h2 class="text-2xl font-semibold text-[var(--color-text-primary)] md:text-3xl">
            Hesapla, rotayı ve fiyat aralığını gör.
          </h2>
          <p class="mt-2 max-w-2xl text-sm text-[var(--color-text-secondary)]">
            Engine kararı saf TypeScript'te alır. OSRM (OpenStreetMap) rotayı çözer,
            BACS engine köprü zincirini ve fiyat bandını üretir.
          </p>
        </div>

        <Calculator client:load />
      </div>
    </section>

    <AlgoPanel />
    <CaseStudy />
    <ContactCTA />

    <!-- Footer -->
    <footer class="border-t border-[var(--color-border-default)] py-10">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
          <div>
            <div class="flex items-center gap-2">
              <span class="font-mono text-xs uppercase tracking-[0.3em] text-[var(--color-accent)]">
                {'{ }'}
              </span>
              <span class="text-base font-extrabold tracking-tighter text-[var(--color-text-primary)]">
                BACS
              </span>
              <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-text-muted)]">
                // labs
              </span>
            </div>
            <p class="mt-2 text-xs text-[var(--color-text-muted)]">
              © 2026 Barış Anıl Consultancy Services A.Ş. — MIT lisanslı vitrin demosu.
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-6 text-xs">
            <a
              href="https://github.com/barisanil1975/bacs-vehicle-aware-routing"
              class="text-[var(--color-text-secondary)] transition hover:text-[var(--color-accent)]"
            >
              GitHub
            </a>
            <a
              href="https://barisanil.com"
              class="text-[var(--color-text-secondary)] transition hover:text-[var(--color-accent)]"
            >
              barisanil.com
            </a>
            <a
              href="https://linkedin.com/in/barisanil"
              class="text-[var(--color-text-secondary)] transition hover:text-[var(--color-accent)]"
            >
              LinkedIn
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
